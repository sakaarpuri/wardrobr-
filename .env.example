# ─── Required ────────────────────────────────────────────────────────────────
# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Skimlinks credentials — https://publishers.skimlinks.com/
SKIMLINKS_API_KEY=
SKIMLINKS_PUBLISHER_ID=

# SerpApi — https://serpapi.com (Google Shopping fallback, instant access, free tier 100/mo)
SERPAPI_KEY=
# RapidAPI Real-Time Product Search — https://rapidapi.com/
RAPIDAPI_HOST=real-time-product-search.p.rapidapi.com
RAPIDAPI_KEY=
# Demo/dev only. When true, Wardrobr will use mock products if live search is unavailable.
ALLOW_MOCK_SEARCH=false

# Your deployed URL (used for OG tags, board share links)
NEXT_PUBLIC_SITE_URL=https://wardrobr.ai

# ─── Phase A/C additions ──────────────────────────────────────────────────────
# Resend — https://resend.com (email board feature)
# IMPORTANT: verify wardrobr.ai sending domain in Resend before going live (SPF/DKIM/DMARC — 24-48h DNS)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Wardrobr.ai <hi@wardrobr.ai>

# PostHog — https://posthog.com (analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Phase 2 (optional now) ──────────────────────────────────────────────────
# Supabase — https://supabase.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
